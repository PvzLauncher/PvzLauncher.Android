<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PvzLauncher.Android.Pages.PageAbout"
             Title="关于">
    <VerticalStackLayout>

        <Border StrokeShape="RoundRectangle 10,10,10,10" Margin="15">
            <VerticalStackLayout>
                <Image Source="icon.png" HeightRequest="128" WidthRequest="128" HorizontalOptions="Center"/>
                <Label Text="Plants Vs. Zombies Launcher for Android" HorizontalOptions="Center" FontAttributes="Bold" FontSize="Medium"/>
                <Grid Margin="10">
                    <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Center">
                        <Label Text="当前版本：" VerticalOptions="Center"/>
                        <Label Text="当前版本" x:Name="VersionBlock" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Button x:Name="button_CheckUpdate" Text="检测更新" VerticalOptions="Center" HorizontalOptions="End" WidthRequest="120" Clicked="Button_Clicked"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
        <BoxView/>
    </VerticalStackLayout>
</ContentPage>