<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PvzLauncher.Android.Pages.PageHome"
             
             Title="主页">
    <Grid>
        <Image x:Name="BackgroundImage" HorizontalOptions="Fill" VerticalOptions="Fill"/>
        <Image Source="title.png" HorizontalOptions="Center" VerticalOptions="Start" Margin="20" x:Name="TitleImage"/>
        <VerticalStackLayout Margin="20" HorizontalOptions="Fill" VerticalOptions="End">
            <Button Text="启动游戏" HeightRequest="60" Margin="5"/>
            <Button Text="启动修改器" HeightRequest="20" Margin="5" Background="{DynamicResource SecondaryDarkText}"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>