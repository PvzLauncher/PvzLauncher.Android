<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PvzLauncher.Android.Pages.PageHome"
             
             Title="主页">
    <Grid>
        <Image x:Name="BackgroundImage" HorizontalOptions="Fill" VerticalOptions="Fill"/>
        <Image Source="title.png" HorizontalOptions="Center" VerticalOptions="Start" Margin="20" x:Name="TitleImage"/>
        <VerticalStackLayout Margin="20" HorizontalOptions="End" VerticalOptions="End">
            <Button Text="&#xe1c4;" FontFamily="MaterialIcons" FontSize="32" HeightRequest="64" WidthRequest="64" Margin="5" CornerRadius="9999"/>
            <Button Text="&#xea3c;" FontSize="18" FontFamily="MaterialIcons" HeightRequest="32" WidthRequest="32" Margin="5" CornerRadius="9999" Background="{DynamicResource SecondaryDarkText}"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>