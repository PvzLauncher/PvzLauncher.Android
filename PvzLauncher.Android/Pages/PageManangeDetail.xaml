<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PvzLauncher.Android.Pages.PageManangeDetail"
             Title="游戏信息">
    <ScrollView>
        <VerticalStackLayout>
            <Border StrokeShape="RoundRectangle 10,10,10,10" Margin="5">
                
                <Grid Margin="5">
                    <Label Text="游戏信息" HorizontalOptions="Center" FontAttributes="Bold" FontSize="Medium"/>
                    <HorizontalStackLayout HorizontalOptions="Start">
                        <Image x:Name="GameImage" Margin="5"  MaximumHeightRequest="64" MaximumWidthRequest="64"/>
                        <VerticalStackLayout Margin="5" VerticalOptions="Center">
                            <Label x:Name="GameTitle" Margin="2.5" FontSize="16" FontAttributes="Bold"/>
                            <Label x:Name="GameNote" Margin="2.5"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout HorizontalOptions="End">
                        <Button Clicked="SetLaunchButton_Clicked" x:Name="SetLaunchButton" Text="&#xe037;" FontSize="18" FontFamily="MaterialIcons" HeightRequest="32" WidthRequest="32" Margin="5" CornerRadius="9999"/>
                    </HorizontalStackLayout>
                </Grid>
            </Border>
            <Border StrokeShape="RoundRectangle 10,10,10,10" Margin="5">
                
                <Grid Margin="5">
                    <Label Text="快捷管理" HorizontalOptions="Center" FontAttributes="Bold" FontSize="Medium"/>
                    <HorizontalStackLayout x:Name="ControlBtns"/>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>