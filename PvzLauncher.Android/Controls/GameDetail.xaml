<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PvzLauncher.Android.Controls.GameDetail">
    <Border StrokeShape="RoundRectangle 10,10,10,10" Margin="5">
        <HorizontalStackLayout>
            <Image x:Name="GameImage" Margin="5"/>
            <VerticalStackLayout Margin="5">
                <Label x:Name="GameTitle"/>
                <HorizontalStackLayout Margin="0,5,0,0">
                    <Border StrokeShape="RoundRectangle 5,5,5,5" Margin="2" Background="Cyan">
                        <Label x:Name="GameNote"/>
                    </Border>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </HorizontalStackLayout>
    </Border>
</ContentView>
