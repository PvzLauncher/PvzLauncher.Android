<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PvzLauncher.Android.Controls.GameDetail">
    <Border StrokeShape="RoundRectangle 10,10,10,10" Margin="5">
        <Grid Margin="5">
            <HorizontalStackLayout HorizontalOptions="Start">
                <Image x:Name="GameImage" Margin="5"  MaximumHeightRequest="64" MaximumWidthRequest="64"/>
                <VerticalStackLayout Margin="5" VerticalOptions="Center">
                    <Label x:Name="GameTitle" Margin="2.5" FontSize="16" FontAttributes="Bold"/>
                    <Label x:Name="GameNote" Margin="2.5"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
            <HorizontalStackLayout HorizontalOptions="End">
                <Button  Clicked="InfoButton_Clicked" x:Name="InfoButton" Text="&#xe315;" FontSize="22" FontFamily="MaterialIcons" HeightRequest="32" WidthRequest="32" Margin="5" CornerRadius="9999"/>
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>
