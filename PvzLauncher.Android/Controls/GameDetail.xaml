<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PvzLauncher.Android.Controls.GameDetail">
    <Border StrokeShape="RoundRectangle 10,10,10,10" Margin="5">
        <HorizontalStackLayout>
            <Image x:Name="GameImage" Margin="5"/>
            <VerticalStackLayout Margin="5">
                <Label x:Name="GameTitle" Margin="5" FontSize="16" FontAttributes="Bold"/>
                <Label x:Name="GameNote" Margin="5"/>
            </VerticalStackLayout>
        </HorizontalStackLayout>
    </Border>
</ContentView>
